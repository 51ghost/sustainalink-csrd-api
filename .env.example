# SustainaLink CSRD API
# Application settings loaded from environment variables

APP_NAME="SustainaLink CSRD API"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL="INFO"

# Server
HOST="0.0.0.0"
PORT=8000

# Database
DATABASE_URL="sqlite+aiosqlite:///./sustainalink_csrd.db"

# CORS
CORS_ORIGINS='["*"]'

# API
API_PREFIX="/api/v1"
